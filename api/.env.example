# ───────────────────────────────────────────────────────────
#  Simples Manutenção — API (.env)
#  Copie este arquivo para .env e preencha os valores reais.
#  Em produção (NODE_ENV=production), API_KEY e JWT_SECRET
#  são OBRIGATÓRIOS — o servidor falha imediatamente sem eles.
# ───────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# Segredos — gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
API_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Persistência
DB_DIR=/data
DATA_FILE=/data/trial-ips.json

# Trial
TRIAL_DAYS=7

# E-mail (Gmail App Password)
GMAIL_USER=appgroupbrasil@gmail.com
GMAIL_PASS=

# URLs públicas
BASE_URL=https://simplesmanutencao.com.br

# CORS — lista separada por vírgula, sem espaços extras
CORS_ORIGINS=https://simplesmanutencao.com.br,https://www.simplesmanutencao.com.br,https://caldo.simplesmanutencao.com.br
